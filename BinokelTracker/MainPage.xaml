<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BinokelTracker"
             xmlns:pages="clr-namespace:BinokelTracker.Pages;assembly=BinokelTracker.Shared"
             x:Class="BinokelTracker.MainPage"
             BackgroundColor="#191613">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type pages:Main}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
