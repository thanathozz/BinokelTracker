@implements IDisposable
@inject BinokelTracker.Shared.Services.ThemeService ThemeService
@inject IAuthService AuthService

@code {
    [Parameter] public List<Spielrunde> Spielrunden { get; set; } = new();
    [Parameter] public List<Game>       AllGames    { get; set; } = new();
    [Parameter] public EventCallback<Spielrunde> OnEnter { get; set; }
    [Parameter] public EventCallback    OnNew       { get; set; }
    [Parameter] public EventCallback    OnLogout    { get; set; }

    private bool   _editingName;
    private string _nameInput = "";

    protected override void OnInitialized()
    {
        AuthService.SessionChanged += OnSessionChanged;
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthService.SessionChanged -= OnSessionChanged;
    }

    private void StartEditName()
    {
        _nameInput   = AuthService.Session?.DisplayName ?? "";
        _editingName = true;
    }

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_nameInput)) return;
        await AuthService.UpdateDisplayNameAsync(_nameInput.Trim());
        _editingName = false;
    }

    private async Task HandleNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveName();
        if (e.Key == "Escape") _editingName = false;
    }

    private Spielrunde? _pendingUnlock;
    private string      _passwordInput = "";
    private bool        _wrongPassword;

    private void TryEnter(Spielrunde s)
    {
        if (string.IsNullOrEmpty(s.PasswordHash))
        {
            OnEnter.InvokeAsync(s);
            return;
        }
        _pendingUnlock = s;
        _passwordInput = "";
        _wrongPassword = false;
    }

    private void SubmitPassword()
    {
        if (_pendingUnlock is null) return;
        if (PasswordHelper.Verify(_passwordInput, _pendingUnlock.PasswordHash!))
        {
            var s = _pendingUnlock;
            _pendingUnlock = null;
            OnEnter.InvokeAsync(s);
        }
        else
        {
            _wrongPassword = true;
            _passwordInput = "";
        }
    }

    private void CancelUnlock()
    {
        _pendingUnlock = null;
        _wrongPassword = false;
        _passwordInput = "";
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SubmitPassword();
    }

    private int GameCount(Spielrunde s)  => AllGames.Count(g => g.SpielrundeId == s.Id);
    private int ActiveCount(Spielrunde s) => AllGames.Count(g => g.SpielrundeId == s.Id && !g.Finished);

    private string FormatDate(Spielrunde s) =>
        new DateTime(1970, 1, 1).AddMilliseconds(s.Id).ToLocalTime().ToString("dd.MM.yyyy");
}

<div>
    <div class="header">
        <div style="display:flex;flex-direction:column;gap:2px">
            <div class="header-title">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><rect x="2" y="4" width="14" height="18" rx="2" transform="rotate(-6 2 4)"/><rect x="8" y="2" width="14" height="18" rx="2" transform="rotate(6 8 2)"/></svg>
                Binokel
            </div>
            @if (_editingName)
            {
                <input class="form-input" style="font-size:12px;padding:3px 8px;height:auto;width:140px"
                       @bind="_nameInput" @bind:event="oninput"
                       @onkeydown="HandleNameKeyDown"
                       @onblur="SaveName"
                       placeholder="Name eingeben" />
            }
            else
            {
                <button class="profile-name-btn" @onclick="StartEditName" title="Namen bearbeiten">
                    @(string.IsNullOrEmpty(AuthService.Session?.DisplayName) ? "Name festlegen" : AuthService.Session.DisplayName)
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="opacity:0.5;margin-left:3px">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </button>
            }
        </div>
        <div style="display:flex;gap:4px">
            <button class="btn" @onclick="OnLogout" title="Abmelden">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </button>
            <button class="btn" @onclick="() => ThemeService.ToggleAsync()" title="Theme wechseln">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M12 3 A9 9 0 0 1 12 21" fill="currentColor"/>
                </svg>
            </button>
            <button class="btn" @onclick="OnNew" title="Neue Spielrunde">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
        </div>
    </div>

    <div class="section">
        @if (Spielrunden.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-suits">♠ ♥ ♣ ♦</div>
                <div class="empty-title">Noch keine Spielrunde</div>
                <div class="empty-sub">Erstelle deine erste Spielrunde!</div>
                <button class="btn-primary" style="max-width:200px;margin:0 auto" @onclick="OnNew">Neue Spielrunde</button>
            </div>
        }

        @foreach (var s in Spielrunden.OrderByDescending(x => x.Id))
        {
            var gameCount  = GameCount(s);
            var activeCount = ActiveCount(s);
            <div class="game-card" @onclick="() => TryEnter(s)">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                    <span style="font-size:16px;font-weight:700">@s.Name</span>
                    <div style="display:flex;gap:6px;align-items:center">
                        @if (!string.IsNullOrEmpty(s.PasswordHash))
                        {
                            <span class="chip chip-muted">Privat</span>
                        }
                        <span class="chip chip-blue">@FormatDate(s)</span>
                    </div>
                </div>
                @if (s.Players.Count > 0)
                {
                    <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px">
                        @foreach (var p in s.Players)
                        {
                            <span class="chip chip-accent">@p</span>
                        }
                    </div>
                }
                <div style="font-size:12px;color:var(--muted)">
                    @gameCount Spiel(e)@(activeCount > 0 ? $" · {activeCount} laufend" : "")
                </div>
            </div>
        }
    </div>

    @if (_pendingUnlock != null)
    {
        <div class="confirm-overlay" @onclick="CancelUnlock">
            <div class="confirm-dialog" @onclick:stopPropagation="true">
                <div class="confirm-title">Passwort eingeben</div>
                <div class="confirm-body" style="margin-bottom:14px">
                    „@_pendingUnlock.Name" ist passwortgeschützt.
                </div>
                <input class="form-input"
                       type="password"
                       placeholder="Passwort"
                       @bind="_passwordInput"
                       @onkeydown="HandleKeyDown"
                       style="margin-bottom:8px" />
                @if (_wrongPassword)
                {
                    <div style="color:var(--red);font-size:13px;margin-bottom:10px">Falsches Passwort.</div>
                }
                <div class="confirm-actions">
                    <button class="btn-secondary" @onclick="CancelUnlock">Abbrechen</button>
                    <button class="btn-primary" style="flex:1" @onclick="SubmitPassword">Öffnen</button>
                </div>
            </div>
        </div>
    }
</div>
