@code {
    [Parameter] public EventCallback<Game>   OnSave         { get; set; }
    [Parameter] public EventCallback         OnCancel       { get; set; }
    [Parameter] public List<string>          KnownPlayers   { get; set; } = new();
    [Parameter] public EventCallback<string> OnRemovePlayer { get; set; }
    [Parameter] public bool                  IsGeneric      { get; set; } = false;

    private List<string> _players     = new() { string.Empty, string.Empty };
    private string       _einsatz     = "0";
    private int          _targetScore = 1000;

    private bool CanSave => _players.All(p => !string.IsNullOrWhiteSpace(p));

    protected override void OnParametersSet()
    {
        if (IsGeneric && _players.All(string.IsNullOrEmpty))
            _players = new List<string> { string.Empty, string.Empty };
    }

    private async Task SaveGeneric()
    {
        if (!CanSave) return;
        var game = new Game
        {
            Id       = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Date     = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Players  = _players.Select(p => p.Trim()).ToList(),
            Rules    = new RuleSet { Id = "generic", Name = "Andere", Players = _players.Count, TargetScore = _targetScore },
            Rounds   = new(),
            Einsatz  = _einsatz,
            Finished = false
        };
        await OnSave.InvokeAsync(game);
    }
}

<div>
    <div class="header">
        <button class="btn" @onclick="OnCancel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <span class="header-title">Neues Spiel</span>
        <div style="width:36px"></div>
    </div>

    <div class="section">
        @if (IsGeneric)
        {
            @if (KnownPlayers.Count > 0)
            {
                <label class="form-label" style="margin-bottom:8px">Bekannte Spieler</label>
                <div class="pill-group" style="flex-wrap:wrap;margin-bottom:14px">
                    @foreach (var kp in KnownPlayers)
                    {
                        var n = kp;
                        var active = _players.Contains(n);
                        <span class="pill @(active ? "active" : "")" style="user-select:none"
                              @onclick="() => { if (active) { var i2 = _players.IndexOf(n); if (i2 >= 0) _players[i2] = string.Empty; } else { var ei = _players.IndexOf(string.Empty); if (ei >= 0) _players[ei] = n; else _players.Add(n); } }">
                            @n
                        </span>
                    }
                </div>
            }
            <label class="form-label" style="margin-bottom:8px">Spieler</label>
            <div style="margin-bottom:16px">
                @for (int i = 0; i < _players.Count; i++)
                {
                    var idx = i;
                    <input class="form-input" style="margin-bottom:6px" placeholder="Spieler @(idx + 1)"
                           value="@_players[idx]" @oninput="e => _players[idx] = e.Value?.ToString() ?? string.Empty" />
                }
                <div style="display:flex;gap:8px;margin-top:6px">
                    <button class="btn-outline" style="flex:1;padding:8px" @onclick="() => _players.Add(string.Empty)">+ Spieler</button>
                    @if (_players.Count > 2)
                    {
                        <button class="btn-outline" style="flex:1;padding:8px;color:var(--red);border-color:rgba(196,92,92,.3)"
                                @onclick="() => _players.RemoveAt(_players.Count - 1)">− Entfernen</button>
                    }
                </div>
            </div>
            <label class="form-label">Zielwert (Punkte)</label>
            <div style="margin-bottom:16px">
                <input class="form-input" type="number" min="1" @bind="_targetScore" @bind:event="oninput" />
            </div>
            <label class="form-label">Einsatz (optional)</label>
            <div style="margin-bottom:20px">
                <input class="form-input" placeholder="z.B. 0.10" @bind="_einsatz" @bind:event="oninput" />
            </div>
            <button class="btn-primary" disabled="@(!CanSave)" style="opacity:@(CanSave ? "1" : "0.4")" @onclick="SaveGeneric">
                Spiel erstellen
            </button>
        }
        else
        {
            <BinokelGameSetup KnownPlayers="KnownPlayers" OnRemovePlayer="OnRemovePlayer" OnSave="OnSave" OnCancel="OnCancel" />
        }
    </div>
</div>
