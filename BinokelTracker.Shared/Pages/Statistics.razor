@code {
    [Parameter] public List<Game> Games { get; set; } = new();
    [Parameter] public EventCallback OnBack { get; set; }

    private enum Tab { Players, Charts }
    private Tab _tab = Tab.Players;
    private GlobalStats _stats = default!;

    protected override void OnParametersSet()
        => _stats = StatisticsService.Compute(Games);

    private static string Pct(double v) => $"{v:F0}%";
    private static string Avg(double v) => $"{v:F0}";

    // Chart data helpers — sorted descending by value
    private IReadOnlyList<(string, double)> ChartWins =>
        _stats.Players
              .OrderByDescending(p => p.GamesWon)
              .Select(p => (p.Name, (double)p.GamesWon))
              .ToList();

    private IReadOnlyList<(string, double)> ChartWinRate =>
        _stats.Players
              .Where(p => p.RoundsAsBidder > 0)
              .OrderByDescending(p => p.BidderWinRate)
              .Select(p => (p.Name, p.BidderWinRate))
              .ToList();

    private IReadOnlyList<(string, double)> ChartAvgBid =>
        _stats.Players
              .Where(p => p.BidCountNotAbg > 0)
              .OrderByDescending(p => p.AvgBidValue)
              .Select(p => (p.Name, p.AvgBidValue))
              .ToList();

    private IReadOnlyList<(string, double)> ChartAbgegangen =>
        _stats.Players
              .Where(p => p.BidderAbgegangen > 0)
              .OrderByDescending(p => p.BidderAbgegangen)
              .Select(p => (p.Name, (double)p.BidderAbgegangen))
              .ToList();

    private IReadOnlyList<(string, double)> ChartBidderLosses =>
        _stats.Players
              .Where(p => p.BidderLosses > 0)
              .OrderByDescending(p => p.BidderLosses)
              .Select(p => (p.Name, (double)p.BidderLosses))
              .ToList();

    private IReadOnlyList<(string, double)> ChartDurch =>
        _stats.Players
              .Where(p => p.DurchPlayed > 0)
              .OrderByDescending(p => p.DurchWon)
              .Select(p => (p.Name, (double)p.DurchWon))
              .ToList();

    private IReadOnlyList<(string, double)> ChartMoney =>
        _stats.Players
              .Where(p => p.MoneyBalance != 0)
              .OrderByDescending(p => p.MoneyBalance)
              .Select(p => (p.Name, (double)p.MoneyBalance))
              .ToList();

    private bool HasMoney => _stats.Players.Any(p => p.MoneyBalance != 0);

    private static Func<double, string> MoneyColor =>
        v => v >= 0 ? "var(--green)" : "var(--red)";

    private static string FormatMoney(decimal v)
    {
        var sign = v > 0 ? "+" : "";
        return $"{sign}{v:F2} €";
    }
}

<div>
    <div class="header header-center">
        <div></div>
        <span class="header-title">Statistiken</span>
        <div style="width:36px"></div>
    </div>

    <!-- KPI-Leiste -->
    <div class="stats-kpi-bar">
        <div class="stats-kpi-cell">
            <div class="stats-kpi-value">@_stats.TotalGames</div>
            <div class="stats-kpi-label">Spiele</div>
        </div>
        <div class="stats-kpi-cell">
            <div class="stats-kpi-value">@_stats.TotalRounds</div>
            <div class="stats-kpi-label">Runden</div>
        </div>
        <div class="stats-kpi-cell">
            <div class="stats-kpi-value">@_stats.Players.Count</div>
            <div class="stats-kpi-label">Spieler</div>
        </div>
        <div class="stats-kpi-cell">
            <div class="stats-kpi-value">@_stats.FinishedGames</div>
            <div class="stats-kpi-label">Beendet</div>
        </div>
    </div>

    <!-- Tab -->
    <div class="mode-toggle-bar">
        <button class="pill pill-sm @(_tab == Tab.Players ? "active" : "")"
                @onclick="() => _tab = Tab.Players">Rangliste</button>
        <button class="pill pill-sm @(_tab == Tab.Charts ? "active" : "")"
                @onclick="() => _tab = Tab.Charts">Diagramme</button>
    </div>

    @if (_stats.Players.Count == 0)
    {
        <div class="section" style="padding-top:8px">
            <div class="empty-state">
                <div class="empty-suits">♠ ♥ ♣ ♦</div>
                <div class="empty-title">Noch keine Daten</div>
                <div class="empty-sub">Spiele erst ein paar Runden!</div>
            </div>
        </div>
    }
    else if (_tab == Tab.Players)
    {
        <div class="section" style="padding-top:8px">
            @foreach (var (p, rank) in _stats.Players.Select((p, i) => (p, i + 1)))
            {
                var badgeClass = rank == 1 ? "gold" : rank == 2 ? "silver" : rank == 3 ? "bronze" : "";
                var rateColor  = p.BidderWinRate >= 60 ? "var(--green)" : p.BidderWinRate >= 40 ? "var(--accent)" : "var(--red)";

                <div class="stat-row">
                    <div class="stat-row-left">
                        <div class="stat-badge @badgeClass">
                            @if (rank == 1 && p.GamesWon > 0)
                            {
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                </svg>
                            }
                            else { @rank }
                        </div>
                        <div style="min-width:0">
                            <div class="stat-name">@p.Name</div>
                            <div class="stat-meta">
                                @if (p.RoundsAsBidder > 0)
                                {
                                    <text>@Pct(p.BidderWinRate) Reizquote</text>
                                    <span class="stat-meta-sep">·</span>
                                    <text>Ø @Avg(p.AvgBidValue)</text>
                                }
                                @if (p.BidderAbgegangen > 0)
                                {
                                    <span class="stat-meta-sep">·</span>
                                    <text>Abg. @(p.BidderAbgegangen)×</text>
                                }
                                @if (p.DurchPlayed > 0)
                                {
                                    <span class="stat-meta-sep">·</span>
                                    <text>D @(p.DurchWon)/@(p.DurchPlayed)</text>
                                }
                                @if (p.BettelPlayed > 0)
                                {
                                    <span class="stat-meta-sep">·</span>
                                    <text>B @(p.BettelWon)/@(p.BettelPlayed)</text>
                                }
                            </div>
                            @if (p.RoundsAsBidder > 0)
                            {
                                <div class="stat-rate-bar">
                                    <div class="stat-rate-fill" style="width:@(Pct(p.BidderWinRate));background:@rateColor"></div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="stat-row-right">
                        <div class="stat-wins-num">@p.GamesWon</div>
                        <div class="stat-played">/ @p.GamesPlayed Sp.</div>
                        @if (p.MoneyBalance != 0)
                        {
                            <div class="stat-money @(p.MoneyBalance >= 0 ? "pos" : "neg")">@FormatMoney(p.MoneyBalance)</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="section" style="padding-top:12px">
            @if (HasMoney)
            {
                <BarChart Title="Gewinn / Verlust (€)" Data="ChartMoney" Unit=" €" ColorResolver="MoneyColor" />
            }
            <BarChart Title="Siege"        Data="ChartWins"    Color="var(--green)" />
            <BarChart Title="Reizquote"    Data="ChartWinRate" Unit="%" FixedMax="100" Color="var(--accent-light)" />
            <BarChart Title="Ø Reizwert"   Data="ChartAvgBid"  Color="var(--accent)" />
            @if (ChartAbgegangen.Count > 0)
            {
                <BarChart Title="Abgegangen" Data="ChartAbgegangen" Color="var(--dark)" />
            }
            @if (ChartBidderLosses.Count > 0)
            {
                <BarChart Title="Überreizt" Data="ChartBidderLosses" Color="var(--red)" />
            }
            @if (ChartDurch.Count > 0)
            {
                <BarChart Title="Durch — Siege" Data="ChartDurch" Color="var(--yellow, #d4a017)" />
            }
        </div>
    }

    <div class="tab-bar-clearance"></div>
</div>
