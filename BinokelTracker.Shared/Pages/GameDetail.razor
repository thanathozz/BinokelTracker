@code {
    [Parameter] public Game Game { get; set; } = default!;
    [Parameter] public List<CustomField> CustomFields { get; set; } = new();
    [Parameter] public bool StrichlisteMode { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback OnAddRound { get; set; }
    [Parameter] public EventCallback<int> OnDeleteRound { get; set; }
    [Parameter] public EventCallback<int> OnEditRound   { get; set; }
    [Parameter] public EventCallback OnFinishGame { get; set; }
    [Parameter] public EventCallback<int> OnTallyPlayer { get; set; }
    [CascadingParameter] public IStrings S { get; set; } = default!;

    private int[] Totals => Game.GetPlayerTotals();
    private int[] DurchTotals => Game.GetDurchTotals();
    private int[] TeamT => Game.Rules.TeamMode ? Game.GetTeamTotals() : new[] { 0, 0 };
    private int Winner => Game.Finished ? Array.IndexOf(Totals, Totals.Max()) : -1;

    private string FormatDate(long ts) =>
        new DateTime(1970, 1, 1).AddMilliseconds(ts).ToLocalTime().ToString("dd.MM.yyyy");

    private double Progress(int score) =>
        Math.Min(100, Math.Max(0, (double)score / Game.Rules.TargetScore * 100));

    private int? _confirmRoundIdx;

    private void AskDeleteRound(int idx) => _confirmRoundIdx = idx;
    private void CancelDeleteRound()     => _confirmRoundIdx = null;
    private async Task ConfirmDeleteRound()
    {
        if (_confirmRoundIdx is not { } idx) return;
        _confirmRoundIdx = null;
        await OnDeleteRound.InvokeAsync(idx);
    }
}

<div>
    <div class="header">
        <button class="btn" @onclick="OnBack">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <span class="header-title">@FormatDate(Game.Date)</span>
        <span class="chip chip-blue" style="font-size:10px">@Game.Rules.Name</span>
        <span class="chip chip-green" style="font-size:10px">@Game.Einsatz</span>
    </div>

    <!-- Scoreboard -->
    <div class="section" style="padding-bottom:6px">
        @if (Game.Rules.TeamMode)
        {
            <div style="display:flex;gap:8px">
                @for (int ti = 0; ti < 2; ti++)
                {
                    var score = TeamT[ti];
                    var isW = Game.Finished && score >= Game.Rules.TargetScore;
                    var teamColor = ti == 0 ? "var(--blue)" : "var(--tuerkis)";
                    <div class="score-col @(isW ? "winner" : "")" style="border-top:3px solid @teamColor">
                        @if (isW) { <div class="score-trophy">★</div> }
                        <div class="score-name">@Game.Players[ti * 2] & @Game.Players[ti * 2 + 1]</div>
                        <div class="score-value @(score >= 0 ? "positive" : "negative")"
                             style="font-size:26px">@score</div>
                        <div class="score-target">
                            @if (isW) { @S.Goal @Game.Rules.TargetScore }
                            else { @(Math.Max(0, Game.Rules.TargetScore - score)) @S.Missing }
                        </div>
                        <div class="progress-bar" style="margin-top:8px;height:4px">
                            <div class="progress-fill @(isW ? "winner" : "")" style="width:@(Progress(score))%"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="score-grid">
                @for (int i = 0; i < Game.Players.Count; i++)
                {
                    var idx = i;
                    var totals = Totals;
                    var durchTotals = DurchTotals;
                    <div class="score-col @(Winner == idx ? "winner" : "")">
                        @if (Winner == idx) { <div class="score-trophy">★</div> }
                        <div class="score-name">@Game.Players[idx]</div>
                        <div class="score-value @(totals[idx] >= 0 ? "positive" : "negative")">@totals[idx]</div>
                        <div class="score-target">
                            @if (Winner == idx) { @S.Goal @Game.Rules.TargetScore }
                            else { @(Math.Max(0, Game.Rules.TargetScore - totals[idx])) @S.Missing }
                        </div>
                        @if (Game.Rules.DurchSeparate && durchTotals[idx] != 0)
                        {
                            <div class="score-durch">D: @(durchTotals[idx] > 0 ? "+" : "")@durchTotals[idx]</div>
                        }
                        <div class="progress-bar">
                            <div class="progress-fill @(Winner == idx ? "winner" : "")"
                                 style="width:@(Progress(totals[idx]))%"></div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Rule chips -->
    <div class="rule-chips">
        @if (Game.Rules.DoubleMinus)
        {
            <span class="chip chip-red">2× Minus</span>
        }
        @if (Game.Rules.AllowDurch)
        {
            <span class="chip chip-yellow">Durch</span>
        }
        @if (Game.Rules.AllowBettel)
        {
            <span class="chip chip-blue">Bettel</span>
        }
        @if (Game.Rules.AllowAbgehen)
        {
            <span class="chip chip-muted">Abgehen</span>
        }
    </div>

    @if (StrichlisteMode)
    {
        <!-- ── Strichliste-Tapper ── -->
        <div class="strichliste-grid">
            @for (int i = 0; i < Game.Players.Count; i++)
            {
                var idx = i;
                var count = Totals.Length > idx ? Totals[idx] : 0;
                <button class="strichliste-card" @onclick="() => OnTallyPlayer.InvokeAsync(idx)">
                    <div class="strichliste-name">@Game.Players[idx]</div>
                    <div class="strichliste-count">@count</div>
                    <div class="strichliste-add">@S.TallyAdd</div>
                </button>
            }
        </div>
        @if (!Game.Finished)
        {
            <div class="section" style="padding-top:0">
                <button class="btn-outline" style="width:100%" @onclick="OnFinishGame">@S.FinishGameBtn</button>
            </div>
        }
        @if (Game.Finished)
        {
            <div class="win-banner">
                @string.Format(S.WinsStrichliste, Game.Players[Array.IndexOf(Totals, Totals.Max())], Totals.Max())
            </div>
        }
    }
    else
    {

    <!-- Rounds -->
    <div class="section" style="padding-top:4px">
        <span class="form-label" style="margin-bottom:10px;display:block">
            @Game.Rounds.Count @(Game.Rounds.Count != 1 ? S.Rounds : S.Round)
        </span>

        @if (Game.Rounds.Count == 0)
        {
            <div style="text-align:center;padding:28px 0;color:var(--dark);font-size:13px">@S.NoRounds</div>
        }

        @for (int ri = 0; ri < Game.Rounds.Count; ri++)
        {
            var r = Game.Rounds[ri];
            var roundIdx = ri;

            <div class="round-card">
                @if (Game.Rules.Id == "generic" && CustomFields.Any())
                {
                    <div style="padding:11px 13px">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                            <span class="round-num">R@(ri + 1)</span>
                                <button class="btn" style="padding:3px;color:var(--dark)"
                                        @onclick="() => AskDeleteRound(roundIdx)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                                        <polyline points="3 6 5 6 21 6"/>
                                        <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                                    </svg>
                                </button>
                        </div>
                        <CustomFieldDisplay Fields="CustomFields" Players="Game.Players" Values="r.CustomValues" />
                    </div>
                }
                else
                {
                    <BinokelRoundCard Round="r" Players="Game.Players" Rules="Game.Rules"
                                      RoundIndex="ri" GameFinished="Game.Finished"
                                      OnDelete="EventCallback.Factory.Create<int>(this, AskDeleteRound)" OnEdit="OnEditRound" />
                } @* end else (not custom fields) *@
            </div>
        }

        @if (!Game.Finished)
        {
            <div class="action-bar">
                <button class="btn-primary" style="flex:2" @onclick="OnAddRound">@S.AddRound</button>
                @if (Game.Rounds.Count > 0)
                {
                    <button class="btn-outline" style="flex:1" @onclick="OnFinishGame">@S.FinishGame</button>
                }
            </div>
        }

        @if (Game.Finished)
        {
            <div class="win-banner">
                @if (Game.Rules.TeamMode)
                {
                    var winTeam = TeamT[0] >= TeamT[1] ? 0 : 1;
                    @string.Format(S.WinsTeam, Game.Players[winTeam * 2], Game.Players[winTeam * 2 + 1])
                }
                else
                {
                    @string.Format(S.WinsWithPoints, Game.Players[Winner], Totals[Winner])
                }
            </div>
        }
        <div class="tab-bar-clearance"></div>
    </div>
    } @* end else (not StrichlisteMode) *@
</div>

@if (_confirmRoundIdx is not null)
{
    <div class="confirm-overlay" @onclick="CancelDeleteRound">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <div class="confirm-title">@S.DeleteRoundTitle</div>
            <div class="confirm-body">@S.DeleteRoundBody</div>
            <div class="confirm-actions">
                <button class="btn-secondary" @onclick="CancelDeleteRound">@S.Cancel</button>
                <button class="btn-danger"    @onclick="ConfirmDeleteRound">@S.Delete</button>
            </div>
        </div>
    </div>
}
