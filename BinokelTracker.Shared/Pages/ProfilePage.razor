@inject IAuthService AuthService
@inject BinokelTracker.Shared.Services.ThemeService ThemeService
@implements IDisposable

@code {
    [Parameter] public EventCallback OnLogout { get; set; }

    private bool   _editingName;
    private string _nameInput = "";

    protected override void OnInitialized()
    {
        AuthService.SessionChanged += OnSessionChanged;
    }

    public void Dispose()
    {
        AuthService.SessionChanged -= OnSessionChanged;
    }

    private void OnSessionChanged() => InvokeAsync(StateHasChanged);

    private void StartEditName()
    {
        _nameInput   = AuthService.Session?.DisplayName ?? "";
        _editingName = true;
    }

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_nameInput)) return;
        await AuthService.UpdateDisplayNameAsync(_nameInput.Trim());
        _editingName = false;
    }

    private async Task HandleNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  await SaveName();
        if (e.Key == "Escape") _editingName = false;
    }
}

<div>
    <div class="header header-center">
        <div></div>
        <div class="header-title">Profil ◉</div>
        <div></div>
    </div>

    <div class="section" style="padding-bottom:80px">

        <!-- Konto -->
        <div class="form-label" style="margin-bottom:10px">Konto</div>
        <div class="stats-card" style="margin-bottom:20px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
                <div>
                    <div style="font-size:12px;color:var(--muted);margin-bottom:4px">E-Mail</div>
                    <div style="font-size:15px;font-weight:600">@(AuthService.Session?.Email ?? "–")</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between">
                <div style="flex:1">
                    <div style="font-size:12px;color:var(--muted);margin-bottom:4px">Anzeigename</div>
                    @if (_editingName)
                    {
                        <input class="form-input" style="font-size:15px;padding:6px 10px;height:auto"
                               @bind="_nameInput" @bind:event="oninput"
                               @onkeydown="HandleNameKeyDown"
                               @onblur="SaveName"
                               placeholder="Name eingeben" />
                    }
                    else
                    {
                        <div style="font-size:15px;font-weight:600">
                            @(string.IsNullOrEmpty(AuthService.Session?.DisplayName) ? "–" : AuthService.Session.DisplayName)
                        </div>
                    }
                </div>
                @if (!_editingName)
                {
                    <button class="btn" @onclick="StartEditName" title="Namen bearbeiten">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </button>
                }
                else
                {
                    <button class="btn" @onclick="SaveName" title="Speichern" style="color:var(--green)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </button>
                }
            </div>
        </div>

        <!-- Erscheinungsbild -->
        <div class="form-label" style="margin-bottom:10px">Erscheinungsbild</div>
        <div class="stats-card" style="margin-bottom:20px">
            <div style="display:flex;align-items:center;justify-content:space-between">
                <div>
                    <div style="font-size:15px;font-weight:600">Design-Theme</div>
                    <div style="font-size:12px;color:var(--muted);margin-top:2px">Warmes Braun / Dunkelgrau</div>
                </div>
                <button class="btn-outline" style="padding:8px 16px;font-size:13px;width:auto" @onclick="() => ThemeService.ToggleAsync()">
                    Wechseln
                </button>
            </div>
        </div>

        <!-- Abmelden -->
        <button class="btn-danger" style="width:100%;border-radius:12px;padding:13px;font-size:16px;font-family:var(--font)"
                @onclick="OnLogout">
            Abmelden
        </button>
    </div>

    <div class="tab-bar-clearance"></div>
</div>
