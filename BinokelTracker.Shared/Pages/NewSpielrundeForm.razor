@code {
    [Parameter] public EventCallback<Spielrunde> OnSave       { get; set; }
    [Parameter] public EventCallback             OnCancel     { get; set; }
    [Parameter] public List<string>              KnownPlayers { get; set; } = new();
    [Parameter] public string                    GameType     { get; set; } = GameTypeInfo.Binokel;

    private string       _name            = "";
    private List<string> _players         = new();
    private bool         _usePassword;
    private string       _password        = "";
    private string       _passwordConfirm = "";
    private int          _assValue        = 11;
    private int          _zehnValue       = 10;
    private int          _koenigValue     = 4;
    private int          _oberValue       = 3;
    private int          _unterValue       = 2;
    private int          _lastTrickBonus  = 10;
    private int          _abgegangenBonus = 10;
    private List<CustomField> _customFields = new();
    private bool _strichlisteMode = false;

    protected override void OnParametersSet()
    {
        if (!GameTypeInfo.IsBinokel(GameType) && _players.Count == 0)
            _players = new List<string> { string.Empty, string.Empty };
    }

    private bool CanSave =>
        !string.IsNullOrWhiteSpace(_name) &&
        (!_usePassword || (_password.Length >= 1 && _password == _passwordConfirm));

    private void TogglePlayer(string name)
    {
        if (_players.Contains(name)) _players.Remove(name);
        else _players.Add(name);
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var s = new Spielrunde
        {
            Id                      = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Name                    = _name.Trim(),
            GameType                = GameType,
            Players                 = _players.ToList(),
            PasswordHash            = _usePassword ? PasswordHelper.Hash(_password) : null,
            AssValue                = _assValue,
            ZehnValue               = _zehnValue,
            KoenigValue             = _koenigValue,
            OberValue               = _oberValue,
            UnterValue               = _unterValue,
            LastTrickBonus          = _lastTrickBonus,
            AbgegangenBonusPerPlayer = _abgegangenBonus,
            CustomFields      = _customFields.ToList(),
            StrichlisteMode   = _strichlisteMode,
        };
        await OnSave.InvokeAsync(s);
    }
}

<div>
    <div class="header">
        <button class="btn" @onclick="OnCancel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <span class="header-title">Neue Spielrunde</span>
        <div style="width:36px"></div>
    </div>

    <div class="section">
        <label class="form-label">Name</label>
        <div style="margin-bottom:16px">
            <input class="form-input" placeholder="z.B. Freitagsrunde"
                   @bind="_name" @bind:event="oninput" />
        </div>

        @if (KnownPlayers.Count > 0)
        {
            <label class="form-label" style="margin-bottom:10px">Spieler</label>
            <div class="pill-group" style="flex-wrap:wrap;margin-bottom:16px">
                @foreach (var name in KnownPlayers)
                {
                    var n = name;
                    var selected = _players.Contains(n);
                    <span class="pill @(selected ? "active" : "")"
                          style="user-select:none"
                          @onclick="() => TogglePlayer(n)">
                        @n
                    </span>
                }
            </div>
        }

        <div class="toggle-row" style="margin-bottom:16px">
            <button class="toggle-track @(_usePassword ? "on" : "off")" @onclick="() => _usePassword = !_usePassword">
                <div class="toggle-knob @(_usePassword ? "on" : "off")"></div>
            </button>
            <span class="toggle-label @(_usePassword ? "on" : "off")">Passwort schützen</span>
        </div>

        @if (_usePassword)
        {
            <div style="margin-bottom:10px">
                <input class="form-input" type="password" placeholder="Passwort"
                       @bind="_password" @bind:event="oninput" />
            </div>
            <div style="margin-bottom:16px">
                <input class="form-input" type="password" placeholder="Passwort bestätigen"
                       @bind="_passwordConfirm" @bind:event="oninput" />
                @if (_usePassword && _password.Length > 0 && _passwordConfirm.Length > 0 && _password != _passwordConfirm)
                {
                    <div style="color:var(--red);font-size:13px;margin-top:6px">Passwörter stimmen nicht überein.</div>
                }
            </div>
        }

        @if (GameTypeInfo.IsBinokel(GameType))
        {
        <label class="form-label" style="margin-top:8px">Kartenwerte (Augen)</label>
        <div style="display:flex;gap:8px;margin-bottom:10px">
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Ass</label>
                <input class="form-input" type="number" min="0"
                       @bind="_assValue" @bind:event="oninput" />
            </div>
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Zehn</label>
                <input class="form-input" type="number" min="0"
                       @bind="_zehnValue" @bind:event="oninput" />
            </div>
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">König</label>
                <input class="form-input" type="number" min="0"
                       @bind="_koenigValue" @bind:event="oninput" />
            </div>
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Ober</label>
                <input class="form-input" type="number" min="0"
                       @bind="_oberValue" @bind:event="oninput" />
            </div>
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Unter</label>
                <input class="form-input" type="number" min="0"
                       @bind="_unterValue" @bind:event="oninput" />
            </div>
        </div>
        <label class="form-label" style="margin-top:4px">Boni</label>
        <div style="display:flex;gap:8px;margin-bottom:16px">
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Letzter Stich</label>
                <input class="form-input" type="number" min="0"
                       @bind="_lastTrickBonus" @bind:event="oninput" />
            </div>
            <div style="flex:1">
                <label class="form-label" style="font-size:12px">Abg.-Bonus/Sp.</label>
                <input class="form-input" type="number" min="0"
                       @bind="_abgegangenBonus" @bind:event="oninput" />
            </div>
        </div>
        } @* end IsBinokel *@

        @if (!GameTypeInfo.IsBinokel(GameType))
        {
            <label class="form-label" style="margin-bottom:8px">Spieler</label>
            <div style="margin-bottom:16px">
                @for (int pi = 0; pi < _players.Count; pi++)
                {
                    var pidx = pi;
                    <input class="form-input" style="margin-bottom:6px" placeholder="Spieler @(pidx + 1)"
                           value="@_players[pidx]"
                           @oninput="e => _players[pidx] = e.Value?.ToString() ?? string.Empty" />
                }
                <div style="display:flex;gap:8px;margin-top:6px">
                    <button class="btn-outline" style="flex:1;padding:8px" type="button" @onclick="() => _players.Add(string.Empty)">+ Spieler</button>
                    @if (_players.Count > 2)
                    {
                        <button class="btn-outline" style="flex:1;padding:8px;color:var(--red);border-color:rgba(196,92,92,.3)" type="button"
                                @onclick="() => _players.RemoveAt(_players.Count - 1)">− Entfernen</button>
                    }
                </div>
            </div>

            <div class="toggle-row" style="margin-bottom:16px">
                <button class="toggle-track @(_strichlisteMode ? "on" : "off")" @onclick="() => _strichlisteMode = !_strichlisteMode">
                    <div class="toggle-knob @(_strichlisteMode ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_strichlisteMode ? "on" : "off")">Strichliste-Modus</span>
            </div>

            @if (!_strichlisteMode)
            {
                <label class="form-label" style="margin-top:4px;margin-bottom:10px">Tracking-Felder</label>
                <CustomFieldBuilder Fields="_customFields" />
            }
        }

        <button class="btn-primary" style="margin-top:8px;opacity:@(CanSave ? "1" : "0.4")" disabled="@(!CanSave)"
                @onclick="Save">
            Spielrunde erstellen
        </button>
    </div>
</div>
