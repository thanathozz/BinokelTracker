@inject IGameStorageService Storage

@code {
    [Parameter] public EventCallback<Spielrunde> OnSave       { get; set; }
    [Parameter] public EventCallback             OnCancel     { get; set; }
    [Parameter] public List<string>              KnownPlayers { get; set; } = new();
    [Parameter] public string                    GameType     { get; set; } = GameTypeInfo.Binokel;
    [Parameter] public string                    CreatorName  { get; set; } = "";
    [CascadingParameter] public IStrings S { get; set; } = default!;

    private string       _name            = "";
    private List<string> _players         = new();
    private bool         _usePassword;
    private string       _password        = "";
    private string       _passwordConfirm = "";
    private int          _assValue        = 11;
    private int          _zehnValue       = 10;
    private int          _koenigValue     = 4;
    private int          _oberValue       = 3;
    private int          _unterValue       = 2;
    private int          _lastTrickBonus  = 10;
    private int          _abgegangenBonus = 10;
    private List<CustomField> _customFields = new();
    private bool _strichlisteMode = false;
    private bool _showAdvanced = false;

    // ── Nick-Invite ──────────────────────────────────────────────────
    private List<(string UserId, string Nick)> _invitedMembers = new();
    private string  _nickInput      = "";
    private bool    _nickSearching  = false;
    private string? _nickSearchError;

    private async Task AddMemberByNick()
    {
        var nick = _nickInput.Trim().ToLowerInvariant().TrimStart('@');
        if (string.IsNullOrEmpty(nick)) return;
        if (_invitedMembers.Any(m => m.Nick == nick)) { _nickInput = ""; return; }

        _nickSearching  = true;
        _nickSearchError = null;
        StateHasChanged();

        var result = await Storage.FindProfileByNickAsync(nick);

        _nickSearching = false;
        if (result is null)
        {
            _nickSearchError = S.NickNotFound;
        }
        else
        {
            _invitedMembers.Add((result.Value.UserId, result.Value.Nick));
            _nickInput       = "";
            _nickSearchError = null;
        }
    }

    private void RemoveMember(string nick) =>
        _invitedMembers.RemoveAll(m => m.Nick == nick);

    private async Task HandleNickInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddMemberByNick();
    }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(CreatorName) && !_players.Contains(CreatorName))
            _players.Add(CreatorName);
    }

    protected override void OnParametersSet()
    {
        if (!GameTypeInfo.IsBinokel(GameType) && _players.Count == 0)
            _players = new List<string> { string.Empty, string.Empty };
    }

    private bool CanSave =>
        !string.IsNullOrWhiteSpace(_name) &&
        (!_usePassword || (_password.Length >= 1 && _password == _passwordConfirm));

    private void TogglePlayer(string name)
    {
        if (_players.Contains(name)) _players.Remove(name);
        else _players.Add(name);
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var s = new Spielrunde
        {
            Id                      = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Name                    = _name.Trim(),
            GameType                = GameType,
            Players                 = _players.ToList(),
            PasswordHash            = _usePassword ? PasswordHelper.Hash(_password) : null,
            AssValue                = _assValue,
            ZehnValue               = _zehnValue,
            KoenigValue             = _koenigValue,
            OberValue               = _oberValue,
            UnterValue               = _unterValue,
            LastTrickBonus          = _lastTrickBonus,
            AbgegangenBonusPerPlayer = _abgegangenBonus,
            CustomFields      = _customFields.ToList(),
            StrichlisteMode   = _strichlisteMode,
            InvitedNicks      = _invitedMembers.Select(m => m.Nick).ToList(),
            PendingInvites    = _invitedMembers.Count > 0 ? _invitedMembers.ToList() : null,
        };
        await OnSave.InvokeAsync(s);
    }
}

<div>
    <div class="header">
        <button class="btn" @onclick="OnCancel">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <span class="header-title">@S.NewSpielrundeTitle</span>
        <div style="width:36px"></div>
    </div>

    <div class="section">
        <label class="form-label">@S.Name</label>
        <div style="margin-bottom:16px">
            <input class="form-input" placeholder="z.B. Freitagsrunde"
                   @bind="_name" @bind:event="oninput" />
        </div>

        @if (KnownPlayers.Count > 0)
        {
            <label class="form-label" style="margin-bottom:10px">@S.Players</label>
            <div class="pill-group" style="flex-wrap:wrap;margin-bottom:16px">
                @foreach (var name in KnownPlayers)
                {
                    var n = name;
                    var selected = _players.Contains(n);
                    <span class="pill @(selected ? "active" : "")"
                          style="user-select:none"
                          @onclick="() => TogglePlayer(n)">
                        @n
                    </span>
                }
            </div>
        }

        <div class="toggle-row" style="margin-bottom:16px">
            <button class="toggle-track @(_usePassword ? "on" : "off")" @onclick="() => _usePassword = !_usePassword">
                <div class="toggle-knob @(_usePassword ? "on" : "off")"></div>
            </button>
            <span class="toggle-label @(_usePassword ? "on" : "off")">@S.UsePassword</span>
        </div>

        @if (_usePassword)
        {
            <div style="margin-bottom:10px">
                <input class="form-input" type="password" placeholder="Passwort"
                       @bind="_password" @bind:event="oninput" />
            </div>
            <div style="margin-bottom:16px">
                <input class="form-input" type="password" placeholder="Passwort bestätigen"
                       @bind="_passwordConfirm" @bind:event="oninput" />
                @if (_usePassword && _password.Length > 0 && _passwordConfirm.Length > 0 && _password != _passwordConfirm)
                {
                    <div style="color:var(--red);font-size:13px;margin-top:6px">@S.PasswordMismatch</div>
                }
            </div>
        }

        <label class="form-label" style="margin-bottom:8px">@S.InviteByNick</label>
        <div style="display:flex;gap:8px;margin-bottom:8px">
            <input class="form-input" style="flex:1;font-family:var(--font-mono)"
                   placeholder="@("@nick")"
                   value="@_nickInput"
                   @oninput="e => _nickInput = e.Value?.ToString() ?? string.Empty"
                   @onkeydown="HandleNickInputKeyDown" />
            <button class="btn-outline" style="padding:8px 14px;white-space:nowrap" type="button"
                    disabled="@_nickSearching"
                    @onclick="AddMemberByNick">
                @(_nickSearching ? "…" : S.AddMember)
            </button>
        </div>
        @if (_nickSearchError != null)
        {
            <div style="color:var(--red);font-size:13px;margin-bottom:8px">@_nickSearchError</div>
        }
        @if (_invitedMembers.Count > 0)
        {
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px">
                @foreach (var m in _invitedMembers)
                {
                    var nick = m.Nick;
                    <span class="chip chip-accent" style="display:flex;align-items:center;gap:5px;font-family:var(--font-mono)">
                        @@@nick
                        <button type="button"
                                style="background:none;border:none;cursor:pointer;color:inherit;padding:0;line-height:1;font-size:14px;opacity:0.7"
                                @onclick="() => RemoveMember(nick)">✕</button>
                    </span>
                }
            </div>
        }
        else
        {
            <div style="margin-bottom:14px"></div>
        }

        @if (GameTypeInfo.IsBinokel(GameType))
        {
            <button class="adv-toggle" @onclick="() => _showAdvanced = !_showAdvanced">
                <span>Erweitert</span>
                <svg class="adv-chevron @(_showAdvanced ? "open" : "")" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <polyline points="6 9 12 15 18 9"/>
                </svg>
            </button>
            @if (_showAdvanced)
            {
                <BinokelSpielrundeSettings
                    @bind-AssValue="_assValue"
                    @bind-ZehnValue="_zehnValue"
                    @bind-KoenigValue="_koenigValue"
                    @bind-OberValue="_oberValue"
                    @bind-UnterValue="_unterValue"
                    @bind-LastTrickBonus="_lastTrickBonus"
                    @bind-AbgegangenBonus="_abgegangenBonus" />
            }
        }

        @if (!GameTypeInfo.IsBinokel(GameType))
        {
            <label class="form-label" style="margin-bottom:8px">@S.Players</label>
            <div style="margin-bottom:16px">
                @for (int pi = 0; pi < _players.Count; pi++)
                {
                    var pidx = pi;
                    <input class="form-input" style="margin-bottom:6px" placeholder="@($"{S.Players} {pidx + 1}")"
                           value="@_players[pidx]"
                           @oninput="e => _players[pidx] = e.Value?.ToString() ?? string.Empty" />
                }
                <div style="display:flex;gap:8px;margin-top:6px">
                    <button class="btn-outline" style="flex:1;padding:8px" type="button" @onclick="() => _players.Add(string.Empty)">@S.AddPlayer</button>
                    @if (_players.Count > 2)
                    {
                        <button class="btn-outline" style="flex:1;padding:8px;color:var(--red);border-color:rgba(196,92,92,.3)" type="button"
                                @onclick="() => _players.RemoveAt(_players.Count - 1)">@S.RemovePlayerBtn</button>
                    }
                </div>
            </div>

            <div class="toggle-row" style="margin-bottom:16px">
                <button class="toggle-track @(_strichlisteMode ? "on" : "off")" @onclick="() => _strichlisteMode = !_strichlisteMode">
                    <div class="toggle-knob @(_strichlisteMode ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_strichlisteMode ? "on" : "off")">@S.StrichlisteMode</span>
            </div>

            @if (!_strichlisteMode)
            {
                <label class="form-label" style="margin-top:4px;margin-bottom:10px">@S.TrackingFields</label>
                <CustomFieldBuilder Fields="_customFields" />
            }
        }

        <button class="btn-primary" style="margin-top:8px;opacity:@(CanSave ? "1" : "0.4")" disabled="@(!CanSave)"
                @onclick="Save">
            @S.CreateSpielrunde
        </button>
    </div>
</div>

<style>
    .adv-toggle {
        display: flex; align-items: center; justify-content: space-between;
        width: 100%; padding: 10px 0; background: none; border: none;
        border-top: 1px solid var(--border); cursor: pointer;
        color: var(--muted); font-size: 14px; font-weight: 600;
        margin-bottom: 4px;
    }
    .adv-chevron { transition: transform 0.2s; }
    .adv-chevron.open { transform: rotate(180deg); }
</style>
