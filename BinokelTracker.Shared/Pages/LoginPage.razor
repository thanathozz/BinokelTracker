@inject IAuthService AuthService

<div class="app-container">
    <div class="app-bg"></div>
    <div class="app-content fade-in">
        <div class="login-card">
            <div class="header-title" style="justify-content:center;margin-bottom:28px;font-size:22px">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                    <rect x="2" y="4" width="14" height="18" rx="2" transform="rotate(-6 2 4)"/>
                    <rect x="8" y="2" width="14" height="18" rx="2" transform="rotate(6 8 2)"/>
                </svg>
                Binokel
            </div>

            @if (_step == Step.Auth)
            {
                <div class="auth-tab-row">
                    <button class="auth-tab @(_mode == Mode.Login ? "active" : "")"
                            @onclick="() => { _mode = Mode.Login; _error = null; }">
                        @S.SignIn
                    </button>
                    <button class="auth-tab @(_mode == Mode.Register ? "active" : "")"
                            @onclick="() => { _mode = Mode.Register; _error = null; }">
                        @S.Register
                    </button>
                </div>

                <div class="form-group" style="margin-top:20px">
                    <label class="form-label">@S.Email</label>
                    <input class="form-input" type="email" placeholder="name@beispiel.de"
                           @bind="_email" @bind:event="oninput" autocomplete="email" />
                </div>

                <div class="form-group">
                    <label class="form-label">Passwort</label>
                    <input class="form-input" type="password" placeholder="Passwort"
                           @bind="_password" @bind:event="oninput"
                           @onkeydown="HandleKeyDown"
                           autocomplete="@(_mode == Mode.Login ? "current-password" : "new-password")" />
                </div>

                @if (_error != null)
                {
                    <div style="color:var(--red);font-size:13px;margin-bottom:12px;line-height:1.4">@_error</div>
                }

                <button class="btn-primary" @onclick="SubmitAuth" disabled="@_loading">
                    @(_loading ? "..." : (_mode == Mode.Login ? S.SignIn : S.Register))
                </button>
            }
            else
            {
                <div style="text-align:center;margin-bottom:20px">
                    <div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:6px">@S.WhatIsYourName</div>
                    <div style="font-size:13px;color:var(--muted)">@S.DisplayNameHint</div>
                </div>

                <div class="form-group">
                    <label class="form-label">@S.DisplayName</label>
                    <input class="form-input" type="text" placeholder="z.B. Max"
                           @bind="_displayName" @bind:event="oninput"
                           @onkeydown="HandleNameKeyDown"
                           autocomplete="nickname" />
                </div>

                @if (_error != null)
                {
                    <div style="color:var(--red);font-size:13px;margin-bottom:12px;line-height:1.4">@_error</div>
                }

                <button class="btn-primary" @onclick="SubmitName" disabled="@_loading">
                    @(_loading ? "..." : S.Continue)
                </button>
            }
            else if (_step == Step.Nick)
            {
                <div style="text-align:center;margin-bottom:20px">
                    <div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:6px">@S.NickLabel</div>
                    <div style="font-size:13px;color:var(--muted)">@S.NickHint</div>
                </div>

                <div class="form-group">
                    <label class="form-label">@S.NickLabel</label>
                    <input class="form-input" type="text" placeholder="z.B. binokel_king"
                           value="@_nick"
                           @oninput="OnNickInput"
                           @onkeydown="HandleNickKeyDown"
                           autocomplete="username" style="font-family:var(--font-mono)" />
                    @if (!string.IsNullOrEmpty(_nick))
                    {
                        @if (_nickChecking)
                        {
                            <div style="font-size:12px;color:var(--muted);margin-top:5px">@S.NickChecking</div>
                        }
                        else if (!NickValid)
                        {
                            <div style="font-size:12px;color:var(--red);margin-top:5px">@S.NickInvalid</div>
                        }
                        else if (_nickAvailable)
                        {
                            <div style="font-size:12px;color:var(--green);margin-top:5px">✓ @S.NickAvailable</div>
                        }
                        else
                        {
                            <div style="font-size:12px;color:var(--red);margin-top:5px">@S.NickTaken</div>
                        }
                    }
                </div>

                @if (_error != null)
                {
                    <div style="color:var(--red);font-size:13px;margin-bottom:12px;line-height:1.4">@_error</div>
                }

                <button class="btn-primary" @onclick="SubmitNick"
                        disabled="@(!NickValid || !_nickAvailable || _nickChecking || _loading)">
                    @(_loading ? "..." : S.Continue)
                </button>
            }
        </div>
    </div>
</div>

@code {
    enum Mode { Login, Register }
    enum Step { Auth, Name, Nick }

    [Parameter] public EventCallback OnLoggedIn { get; set; }
    [CascadingParameter] public IStrings S { get; set; } = new StringsDe();

    private Mode    _mode         = Mode.Login;
    private Step    _step         = Step.Auth;
    private string  _email        = "";
    private string  _password     = "";
    private string  _displayName  = "";
    private string  _nick         = "";
    private bool    _nickChecking  = false;
    private bool    _nickAvailable = false;
    private System.Threading.Timer? _debounce;
    private string? _error;
    private bool    _loading;

    private bool NickValid =>
        System.Text.RegularExpressions.Regex.IsMatch(_nick, @"^[a-z0-9_]{3,20}$");

    private async Task SubmitAuth()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = S.MissingCredentials;
            return;
        }

        _error   = null;
        _loading = true;
        StateHasChanged();

        try
        {
            var result = _mode == Mode.Login
                ? await AuthService.LoginAsync(_email, _password)
                : await AuthService.RegisterAsync(_email, _password);

            if (!result.Success)
            {
                _error = result.ErrorMessage;
                return;
            }

            if (string.IsNullOrEmpty(AuthService.Session?.DisplayName))
                _step = Step.Name;
            else if (string.IsNullOrEmpty(AuthService.Session?.Nick))
                _step = Step.Nick;
            else
                await OnLoggedIn.InvokeAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitName()
    {
        if (string.IsNullOrWhiteSpace(_displayName))
        {
            _error = S.MissingName;
            return;
        }

        _error   = null;
        _loading = true;
        StateHasChanged();

        try
        {
            var result = await AuthService.UpdateDisplayNameAsync(_displayName.Trim());
            if (!result.Success)
            {
                _error = result.ErrorMessage;
                return;
            }
            if (string.IsNullOrEmpty(AuthService.Session?.Nick))
                _step = Step.Nick;
            else
                await OnLoggedIn.InvokeAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitNick()
    {
        if (!NickValid || !_nickAvailable || _nickChecking) return;
        _error   = null;
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await AuthService.SetNickAsync(_nick);
            if (!result.Success) { _error = result.ErrorMessage; return; }
            await OnLoggedIn.InvokeAsync();
        }
        finally { _loading = false; }
    }

    private void OnNickInput(ChangeEventArgs e)
    {
        _nick         = (e.Value?.ToString() ?? "").ToLowerInvariant();
        _nickAvailable = false;
        _debounce?.Dispose();

        if (!NickValid) { _nickChecking = false; StateHasChanged(); return; }

        _nickChecking = true;
        StateHasChanged();
        _debounce = new System.Threading.Timer(async _ =>
        {
            _nickAvailable = await AuthService.CheckNickAvailableAsync(_nick);
            _nickChecking  = false;
            await InvokeAsync(StateHasChanged);
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitAuth();
    }

    private async Task HandleNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitName();
    }

    private async Task HandleNickKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SubmitNick();
    }
}
