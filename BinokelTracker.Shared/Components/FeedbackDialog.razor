@inject IFeedbackService FeedbackService

@if (_open)
{
    <div class="feedback-overlay" @onclick="Close">
        <div class="feedback-dialog" @onclick:stopPropagation>
            <div class="feedback-dialog-header">
                <span class="feedback-dialog-title">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Bug melden
                </span>
                <button class="btn" @onclick="Close" style="padding:4px">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            @if (_screenshot != null)
            {
                <div class="feedback-preview-wrap">
                    <img src="data:image/png;base64,@Convert.ToBase64String(_screenshot)"
                         class="feedback-preview"
                         alt="Screenshot" />
                    <div class="feedback-preview-label">Screenshot</div>
                </div>
            }
            else
            {
                <div class="feedback-no-screenshot">Kein Screenshot verfügbar</div>
            }

            <textarea class="feedback-textarea"
                      @bind="_comment"
                      @bind:event="oninput"
                      placeholder="Was ist passiert? Beschreibe den Bug kurz..." />

            <div class="feedback-actions">
                <button class="btn-secondary" @onclick="Close" disabled="@_sending">Abbrechen</button>
                <button class="btn-primary" @onclick="Send" disabled="@_sending" style="flex:1">
                    @if (_sending)
                    {
                        <span>Wird gesendet…</span>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" style="margin-right:6px">
                            <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
                        </svg>
                        <span>Senden</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<button class="feedback-fab" @onclick="OpenFeedback" title="Bug melden">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
        <path d="M9 9a3 3 0 0 1 5.12-2.12M12 17h.01"/>
        <line x1="12" y1="13" x2="12" y2="13.01"/>
    </svg>
</button>

@code {
    private bool _open;
    private string _comment = "";
    private byte[]? _screenshot;
    private bool _sending;

    private async Task OpenFeedback()
    {
        _screenshot = await FeedbackService.CaptureScreenshotAsync();
        _open = true;
        StateHasChanged();
    }

    private void Close()
    {
        if (_sending) return;
        _open = false;
        _comment = "";
        _screenshot = null;
    }

    private async Task Send()
    {
        _sending = true;
        StateHasChanged();
        await FeedbackService.SendFeedbackAsync(_comment, _screenshot);
        _sending = false;
        Close();
    }
}
