@if (_open)
{
    <div class="calc-overlay" @onclick="Close">
        <div class="calc-dialog" @onclick:stopPropagation>

            <div class="calc-header">
                <span class="calc-title">Augen Rechner</span>
                <div style="display:flex;gap:6px">
                    <button class="btn" @onclick="Reset" style="padding:4px 10px;font-size:13px">Reset</button>
                    <button class="btn" @onclick="Close" style="padding:4px">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="calc-total">
                <div class="calc-total-value">@Total</div>
                <div class="calc-total-label">Gesamtpunkte</div>
            </div>

            <div class="calc-rows">
                @for (int i = 0; i < CardNames.Length; i++)
                {
                    var idx = i;
                    <div class="calc-row">
                        <div class="calc-card-label">
                            <span class="calc-card-name">@CardNames[idx]</span>
                            <span class="calc-card-value">@_cardValues[idx] Pkt.</span>
                        </div>
                        <div class="calc-counter">
                            <button class="calc-btn calc-btn-minus" @onclick="() => Sub(idx)" disabled="@(_counts[idx] == 0)">−</button>
                            <span class="calc-count">@_counts[idx]</span>
                            <button class="calc-btn calc-btn-plus" @onclick="() => Add(idx)">+</button>
                        </div>
                    </div>
                }
            </div>

            <div class="calc-last-trick">
                <div>
                    <span class="calc-card-name">Letzter Stich</span>
                    <span class="calc-card-value">+@_lastTrickBonus Pkt.</span>
                </div>
                <button class="toggle-btn @(_letzterStich ? "on" : "off")" @onclick="() => _letzterStich = !_letzterStich">
                    @(_letzterStich ? "Ja" : "Nein")
                </button>
            </div>

            @if (_players != null && _onAssign != null)
            {
                <div class="calc-assign">
                    <div class="calc-assign-label">Punkte übertragen an:</div>
                    <div class="pill-group" style="flex-wrap:wrap">
                        @for (int i = 0; i < _players.Count; i++)
                        {
                            var idx = i;
                            <button class="pill" style="flex:1;min-width:80px" @onclick="() => Assign(idx)">@_players[idx]</button>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
}

@code {
    private bool _open;
    private int[] _counts = new int[5];
    private bool _letzterStich;
    private IReadOnlyList<string>? _players;
    private Action<int, int>? _onAssign;
    private int _lastTrickBonus = 10;

    private static readonly string[] CardNames = { "Ass", "Zehn", "König", "Dame", "Bube" };
    private int[] _cardValues = { 11, 10, 4, 3, 2 };

    private int Total =>
        _counts.Select((c, i) => c * _cardValues[i]).Sum()
        + (_letzterStich ? _lastTrickBonus : 0);

    public void Open(IReadOnlyList<string>? players = null, Action<int, int>? onAssign = null,
                     int assValue = 11, int zehnValue = 10, int koenigValue = 4,
                     int dameValue = 3, int bubeValue = 2, int lastTrickBonus = 10)
    {
        _open = true;
        _players = players;
        _onAssign = onAssign;
        _lastTrickBonus = lastTrickBonus;
        _cardValues = new[] { assValue, zehnValue, koenigValue, dameValue, bubeValue };
        StateHasChanged();
    }

    private void Close()
    {
        _open = false;
        _players = null;
        _onAssign = null;
        _counts = new int[5];
        _letzterStich = false;
    }

    private void Reset()
    {
        _counts = new int[5];
        _letzterStich = false;
    }

    private void Assign(int playerIdx)
    {
        _onAssign?.Invoke(playerIdx, Total);
        _counts = new int[5];
        _letzterStich = false;
    }

    private void Add(int i) => _counts[i]++;

    private void Sub(int i) { if (_counts[i] > 0) _counts[i]--; }
}

<style>
    .calc-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        z-index: 400;
        display: flex;
        align-items: flex-end;
        justify-content: center;
    }

    .calc-dialog {
        background: var(--card);
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        width: 100%;
        max-width: 480px;
        padding: 20px 20px 36px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .calc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .calc-title {
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
    }

    .calc-total {
        text-align: center;
        padding: 12px 0 4px;
    }

    .calc-total-value {
        font-size: 52px;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
    }

    .calc-total-label {
        font-size: 13px;
        color: var(--muted);
        margin-top: 4px;
    }

    .calc-rows {
        display: flex;
        flex-direction: column;
        gap: 2px;
        background: var(--surface);
        border-radius: 12px;
        padding: 4px 0;
    }

    .calc-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid var(--border);
    }

    .calc-rows .calc-row:last-child {
        border-bottom: none;
    }

    .calc-card-label {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .calc-card-name {
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
    }

    .calc-card-value {
        font-size: 12px;
        color: var(--muted);
    }

    .calc-counter {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .calc-count {
        font-size: 20px;
        font-weight: 700;
        color: var(--text);
        min-width: 28px;
        text-align: center;
    }

    .calc-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        font-size: 22px;
        font-weight: 700;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.15s;
    }

    .calc-btn:disabled {
        opacity: 0.3;
        cursor: default;
    }

    .calc-btn-minus {
        background: var(--surface);
        color: var(--text);
    }

    .calc-btn-plus {
        background: var(--accent);
        color: #fff;
    }

    .calc-last-trick {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        background: var(--surface);
        border-radius: 12px;
    }

    .calc-assign {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 14px 16px;
        background: var(--surface);
        border-radius: 12px;
        border: 1px solid var(--accent);
    }

    .calc-assign-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--accent-light);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>
