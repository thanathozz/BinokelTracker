@code {
    [Parameter] public List<string>          KnownPlayers     { get; set; } = new();
    [Parameter] public EventCallback<string> OnRemovePlayer   { get; set; }
    [Parameter] public EventCallback<Game>   OnSave           { get; set; }
    [Parameter] public EventCallback         OnCancel         { get; set; }
    [CascadingParameter] public IStrings S { get; set; } = default!;

    private string       _preset      = "schwaebisch_klassisch";
    private RuleSet      _rules       = RulePresets.All["schwaebisch_klassisch"].Clone();
    private List<string>    _players       = new() { "", "", "" };
    private HashSet<string> _lockedPlayers = new(StringComparer.OrdinalIgnoreCase);
    private string          _einsatz       = "0";
    private bool            _showCustom;

    private string?                  _deleteCandidate;
    private string?                  _exitCandidate;
    private CancellationTokenSource? _longPressCts;
    private string?                  _confirmName;

    private bool CanSave => _players.All(p => !string.IsNullOrWhiteSpace(p));

    private void ChangePreset(ChangeEventArgs e)
    {
        _preset = e.Value?.ToString() ?? "schwaebisch_klassisch";
        _rules  = RulePresets.All[_preset].Clone();
        AdjustPlayers();
        _showCustom = _preset == "benutzerdefiniert";
    }

    private void AdjustPlayers()
    {
        while (_players.Count < _rules.Players) _players.Add("");
        while (_players.Count > _rules.Players)
        {
            _lockedPlayers.Remove(_players[_players.Count - 1]);
            _players.RemoveAt(_players.Count - 1);
        }
        if (_rules.Players != 4) _rules.TeamMode = false;
    }

    private void SetPlayerCount(int count) { _rules.Players = count; AdjustPlayers(); }

    private void ToggleKnownPlayer(string name)
    {
        if (_deleteCandidate == name || _exitCandidate == name) return;
        var existing = _players.IndexOf(name);
        if (existing >= 0) { _players[existing] = ""; _lockedPlayers.Remove(name); return; }
        var empty = _players.IndexOf("");
        if (empty >= 0) { _players[empty] = name; _lockedPlayers.Add(name); }
    }

    private async Task StartLongPress(string name)
    {
        _longPressCts?.Cancel();
        _longPressCts = new CancellationTokenSource();
        var token = _longPressCts.Token;
        try
        {
            await Task.Delay(500, token);
            if (_deleteCandidate == name)
            {
                _deleteCandidate = null;
                _exitCandidate   = name;
                StateHasChanged();
                await Task.Delay(350);
                _exitCandidate = null;
            }
            else { _deleteCandidate = name; }
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private void CancelLongPress() => _longPressCts?.Cancel();
    private void DismissDelete()   => _deleteCandidate = null;
    private void AskRemovePlayer(string name) => _confirmName = name;
    private void CancelRemove() => _confirmName = null;

    private async Task ConfirmRemovePlayer()
    {
        if (_confirmName is null) return;
        var name = _confirmName;
        _confirmName = _deleteCandidate = null;
        var idx = _players.IndexOf(name);
        if (idx >= 0) _players[idx] = "";
        _lockedPlayers.Remove(name);
        await OnRemovePlayer.InvokeAsync(name);
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var game = new Game
        {
            Id      = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Date    = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds(),
            Players = _players.Select(p => p.Trim()).ToList(),
            Rules   = _rules.Clone(),
            Rounds  = new(),
            Einsatz = _einsatz,
            Finished = false
        };
        await OnSave.InvokeAsync(game);
    }
}

@if (_confirmName is not null)
{
    <div class="confirm-overlay" @onclick="CancelRemove">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <div class="confirm-title">@S.RemovePlayerTitle</div>
            <div class="confirm-body">„@_confirmName" @S.RemovePlayerBody</div>
            <div class="confirm-actions">
                <button class="btn-secondary" @onclick="CancelRemove">@S.Cancel</button>
                <button class="btn-danger" @onclick="ConfirmRemovePlayer">@S.Delete</button>
            </div>
        </div>
    </div>
}

<label class="form-label">@S.Rules</label>
<select class="form-select" value="@_preset" @onchange="ChangePreset">
    @foreach (var p in RulePresets.All.Values)
    {
        <option value="@p.Id">@p.Name — @p.Description</option>
    }
</select>

@if (!_showCustom)
{
    <div class="rule-summary">
        <span style="color:var(--accent-light);font-weight:600">@_rules.Players @S.Players</span>
        @if (_rules.TeamMode) { <span> · @S.Teams</span> }
        <span> · @S.Goal <b style="color:var(--text)">@_rules.TargetScore</b></span>
        @if (_rules.DoubleMinus) { <span> · <span style="color:var(--red)">Doppelt Minus</span></span> }
        @if (_rules.AllowDurch)  { <span> · Durch</span> }
        @if (_rules.AllowBettel) { <span> · Bettel</span> }
        @if (_rules.AllowAbgehen){ <span> · Abgehen</span> }
    </div>
}
else
{
    <div class="custom-rules">
        <div class="rule-row">
            <label class="form-label">@S.PlayerCount</label>
            <div class="pill-group">
                <button class="pill pill-sm @(_rules.Players == 3 ? "active" : "")" @onclick="() => SetPlayerCount(3)">3</button>
                <button class="pill pill-sm @(_rules.Players == 4 ? "active" : "")" @onclick="() => SetPlayerCount(4)">4</button>
            </div>
        </div>
        @if (_rules.Players == 4)
        {
            <div class="rule-row">
                <label class="form-label">@S.TeamModeLabel</label>
                <div class="toggle-row">
                    <button class="toggle-track @(_rules.TeamMode ? "on" : "off")" @onclick="() => _rules.TeamMode = !_rules.TeamMode">
                        <div class="toggle-knob @(_rules.TeamMode ? "on" : "off")"></div>
                    </button>
                    <span class="toggle-label @(_rules.TeamMode ? "on" : "off")">@(_rules.TeamMode ? S.Yes : S.No)</span>
                </div>
            </div>
        }
        <div class="rule-row">
            <label class="form-label">@S.TargetPoints</label>
            <div class="pill-group">
                @foreach (var s in new[] { 500, 1000, 1500, 2000 })
                {
                    var val = s;
                    <button class="pill mono @(_rules.TargetScore == val ? "active" : "")" @onclick="() => _rules.TargetScore = val">@val</button>
                }
            </div>
        </div>
        <div class="rule-row">
            <label class="form-label">@S.DoubleMinus</label>
            <div class="toggle-row">
                <button class="toggle-track @(_rules.DoubleMinus ? "on" : "off")" @onclick="() => _rules.DoubleMinus = !_rules.DoubleMinus">
                    <div class="toggle-knob @(_rules.DoubleMinus ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_rules.DoubleMinus ? "on" : "off")">@(_rules.DoubleMinus ? S.Yes : S.No)</span>
            </div>
        </div>
        <div class="rule-row">
            <label class="form-label">@S.AllowDurch</label>
            <div class="toggle-row">
                <button class="toggle-track @(_rules.AllowDurch ? "on" : "off")" @onclick="() => _rules.AllowDurch = !_rules.AllowDurch">
                    <div class="toggle-knob @(_rules.AllowDurch ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_rules.AllowDurch ? "on" : "off")">@(_rules.AllowDurch ? S.Yes : S.No)</span>
            </div>
        </div>
        <div class="rule-row">
            <label class="form-label">@S.AllowBettel</label>
            <div class="toggle-row">
                <button class="toggle-track @(_rules.AllowBettel ? "on" : "off")" @onclick="() => _rules.AllowBettel = !_rules.AllowBettel">
                    <div class="toggle-knob @(_rules.AllowBettel ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_rules.AllowBettel ? "on" : "off")">@(_rules.AllowBettel ? S.Yes : S.No)</span>
            </div>
        </div>
        <div class="rule-row">
            <label class="form-label">@S.AllowAbgehen</label>
            <div class="toggle-row">
                <button class="toggle-track @(_rules.AllowAbgehen ? "on" : "off")" @onclick="() => _rules.AllowAbgehen = !_rules.AllowAbgehen">
                    <div class="toggle-knob @(_rules.AllowAbgehen ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_rules.AllowAbgehen ? "on" : "off")">@(_rules.AllowAbgehen ? S.Yes : S.No)</span>
            </div>
        </div>
        <div class="rule-row" style="margin-bottom:8px">
            <label class="form-label">@S.DurchSeparate</label>
            <div class="toggle-row">
                <button class="toggle-track @(_rules.DurchSeparate ? "on" : "off")" @onclick="() => _rules.DurchSeparate = !_rules.DurchSeparate">
                    <div class="toggle-knob @(_rules.DurchSeparate ? "on" : "off")"></div>
                </button>
                <span class="toggle-label @(_rules.DurchSeparate ? "on" : "off")">@(_rules.DurchSeparate ? S.Yes : S.No)</span>
            </div>
        </div>
    </div>
}

<label class="form-label" style="margin-bottom:10px">@S.Stakes</label>
<div style="margin-bottom:10px">
    <input class="form-input" value="0" @oninput="e => _einsatz = e.Value?.ToString() ?? string.Empty" />
</div>

<label class="form-label" style="margin-bottom:10px">@S.Players</label>
@if (KnownPlayers.Count > 0)
{
    <div class="pill-group" style="flex-wrap:wrap;margin-bottom:10px" @onclick="DismissDelete">
        @foreach (var name in KnownPlayers)
        {
            var n = name;
            var selected  = _players.Contains(n);
            var delMode   = _deleteCandidate == n;
            var exitMode  = _exitCandidate == n;
            <span class="pill @(selected ? "active" : "") @(delMode ? "pill-delete" : exitMode ? "pill-delete-exit" : "")"
                  style="display:inline-flex;align-items:center;gap:4px;user-select:none"
                  @onclick:stopPropagation="true"
                  @onclick="() => { if (!delMode) ToggleKnownPlayer(n); }"
                  @onpointerdown="() => StartLongPress(n)"
                  @onpointerup="CancelLongPress"
                  @onpointerleave="CancelLongPress">
                @n
                @if (delMode)
                {
                    <button style="background:none;border:none;padding:0;margin-left:2px;cursor:pointer;color:inherit;font-size:0.9em;line-height:1"
                            @onclick:stopPropagation="true"
                            @onclick="() => AskRemovePlayer(n)">✕</button>
                }
            </span>
        }
    </div>
}
@for (int i = 0; i < _players.Count; i++)
{
    var idx = i;
    var locked = _lockedPlayers.Contains(_players[idx]);
    var ts = _rules.TeamMode ? $"border-left:3px solid {(idx < 2 ? "var(--blue)" : "var(--tuerkis)")};padding-left:8px;" : "";
    <div style="margin-bottom:10px;@ts">
        <input class="form-input" value="@_players[idx]"
               placeholder="@(_rules.TeamMode ? $"{(idx < 2 ? "Team 1" : "Team 2")} — {S.Players} {idx % 2 + 1}" : $"{S.Players} {idx + 1}")"
               style="@(locked ? "opacity:0.5;background:var(--input-bg,var(--card));cursor:default" : "")"
               disabled="@locked"
               @oninput="e => _players[idx] = e.Value?.ToString() ?? string.Empty" />
    </div>
}
@if (_rules.TeamMode) { <div class="team-hint">@S.TeamHint</div> }

<button class="btn-primary" style="margin-top:8px;opacity:@(CanSave ? "1" : "0.4")" disabled="@(!CanSave)" @onclick="Save">
    @S.StartGame
</button>
