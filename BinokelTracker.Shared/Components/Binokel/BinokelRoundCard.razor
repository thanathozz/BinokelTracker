@code {
    [Parameter] public Round        Round        { get; set; } = default!;
    [Parameter] public List<string> Players      { get; set; } = new();
    [Parameter] public RuleSet      Rules        { get; set; } = default!;
    [Parameter] public int          RoundIndex   { get; set; }
    [Parameter] public bool         GameFinished { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback<int> OnEdit   { get; set; }
    [CascadingParameter] public IStrings S { get; set; } = default!;

    private int[] Scores       => Round.CalcScores(Rules);
    private bool  IsSpecial    => Round.Type is RoundType.Durch or RoundType.Bettel;
    private bool  IsAbgegangen => Round.Abgegangen;

    private string StripClass => Round.Type switch
    {
        RoundType.Durch  => "rc-strip-durch",
        RoundType.Bettel => "rc-strip-bettel",
        _                => Round.Won ? "rc-strip-win" : "rc-strip-loss"
    };

    private string TypeTag => Round.Type switch
    {
        RoundType.Durch  => S.TagDurch,
        RoundType.Bettel => S.TagBettel,
        _                => S.TagNormal
    };

    private string TypeTagClass => Round.Type switch
    {
        RoundType.Durch  => "rc-tag-durch",
        RoundType.Bettel => "rc-tag-bettel",
        _                => "rc-tag-normal"
    };

    private string OutcomeTag      => IsAbgegangen ? S.TagFolded : Round.Won ? S.TagWon : S.TagLost;
    private string OutcomeTagClass => Round.Won && !IsAbgegangen ? "rc-tag-win" : "rc-tag-loss";

    private int BidderMeld   => Round.PlayerScores.Count > Round.Bidder ? Round.PlayerScores[Round.Bidder].Meld   : 0;
    private int BidderTricks => Round.PlayerScores.Count > Round.Bidder ? Round.PlayerScores[Round.Bidder].Tricks : 0;

    private string TypeLabel => Round.Type switch
    {
        RoundType.Durch  => "Durch",
        RoundType.Bettel => "Bettel",
        _                => ""
    };

    private ScoreBreakdown[]? _breakdown;
    private ScoreBreakdown[] Breakdown => _breakdown ??= Round.PlayerScores.Count == Players.Count
        ? ScoringCalculator.CalcNormalPreview(
            Round.Bidder, Round.Bid,
            Round.PlayerScores.Select(ps => ps.Abgegangen).ToArray(),
            Round.PlayerScores.Select(ps => ps.Meld).ToArray(),
            Round.PlayerScores.Select(ps => ps.Tricks).ToArray(),
            Rules, Round.LastTrickWinner)
        : Array.Empty<ScoreBreakdown>();

    private string LocalizeLossReason(string? r) => r switch
    {
        "Reizer abgegangen"                 => S.BidderFolded,
        "Abgegangen"                        => S.Folded,
        "Kein Stich — Meldung verfallen"    => S.NoTrickMeld,
        "Reizwert nicht erreicht"           => S.NotFulfilled,
        _                                   => r ?? ""
    };
}

<!-- Color strip -->
<div class="rc-strip @StripClass"></div>

<!-- Header: round number + type/outcome tags + action buttons -->
<div class="rc-head">
    <span class="rc-num">@S.RoundPrefix @(RoundIndex + 1)</span>
    <div class="rc-tags">
        <span class="rc-tag @TypeTagClass">@TypeTag</span>
        <span class="rc-tag @OutcomeTagClass">@OutcomeTag</span>
        <button class="btn" style="padding:2px;color:var(--dark)" @onclick="() => OnEdit.InvokeAsync(RoundIndex)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
        </button>
        <button class="btn" style="padding:2px;color:var(--dark)" @onclick="() => OnDelete.InvokeAsync(RoundIndex)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="3 6 5 6 21 6"/>
                <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
            </svg>
        </button>
    </div>
</div>

<!-- Summary sentence -->
<div class="rc-summary">
    <span class="rc-bidder-name">@Players[Round.Bidder]</span>
    @if (IsSpecial)
    {
        <span class="rc-summary-text"> @(Round.Type == RoundType.Durch ? S.PlaysDurch : S.PlaysBettel) </span><b>@TypeLabel</b>
        <span class="rc-arrow"> · </span>
        <span class="rc-result-text @(Round.Won ? "win" : "loss")">@(Round.Won ? S.WonWord : S.LostWord)</span>
    }
    else if (IsAbgegangen)
    {
        <span class="rc-arrow"> @S.Bids</span>@(" ")<span class="rc-bid-val">@Round.Bid</span>
        <span class="rc-arrow"> → </span>
        <span class="rc-result-text loss">@S.FoldedWord</span>
    }
    else if (Round.Won)
    {
        <span class="rc-arrow"> @S.Bids</span>@(" ")<span class="rc-bid-val">@Round.Bid</span>
        <span class="rc-arrow"> → </span>
        <span class="rc-result-text win">@(BidderMeld + BidderTricks) @S.Points</span>
    }
    else
    {
        <span class="rc-arrow"> @S.Bids</span>@(" ")<span class="rc-bid-val">@Round.Bid</span>
        <span class="rc-arrow"> → </span>
        <span class="rc-result-text loss">@S.NotFulfilled</span>
    }
</div>

<!-- Player table -->
<div class="rc-player-table">
    @for (int pi = 0; pi < Players.Count; pi++)
    {
        var pIdx     = pi;
        var isBidder = pIdx == Round.Bidder;
        var delta    = Scores[pIdx];
        var bd       = (!IsSpecial && pIdx < Breakdown.Length) ? Breakdown[pIdx] : null;

        <div class="rc-player-row @(isBidder ? "rc-bidder-row" : "")">
            <!-- Line 1: name + role badge | delta pill -->
            <div class="rc-pl-line1">
                <div class="rc-pl-name">
                    <span class="rc-bidder-dot @(isBidder ? "show" : "")"></span>
                    @Players[pIdx]
                    @if (isBidder && !IsSpecial)
                    {
                        <span class="rc-role-badge">@S.Bidder</span>
                    }
                </div>
                <div class="rc-pl-delta @(delta > 0 ? "pos" : delta < 0 ? "neg" : "zero")">
                    @(delta == 0 ? "±0" : delta > 0 ? $"+{delta}" : delta.ToString())
                </div>
            </div>
            <!-- Line 2: calc breakdown or loss note -->
            @if (bd != null && !bd.IsLoss && string.IsNullOrEmpty(bd.LossReason)
                 && (bd.Meld > 0 || bd.Tricks > 0 || bd.Bonus > 0))
            {
                <div class="rc-pl-calc">
                    @if (bd.Meld > 0)
                    {
                        <span class="rc-calc-val">@bd.Meld</span>
                        <span class="rc-calc-label">@S.MeldLabel</span>
                    }
                    @if (bd.Meld > 0 && bd.Tricks > 0)
                    {
                        <span class="rc-calc-op">+</span>
                    }
                    @if (bd.Tricks > 0)
                    {
                        <span class="rc-calc-val">@bd.Tricks</span>
                        <span class="rc-calc-label">@S.TricksLabel</span>
                    }
                    @if (bd.Bonus > 0)
                    {
                        <span class="rc-calc-op">+</span>
                        <span class="rc-calc-bonus">
                            <span class="rc-calc-val">+@bd.Bonus</span>
                            <span class="rc-calc-bonus-label">@S.FoldedAbbr</span>
                        </span>
                    }
                    @if (bd.LastTrickBonus > 0)
                    {
                        <span class="rc-calc-op">+</span>
                        <span class="rc-calc-bonus">
                            <span class="rc-calc-val">+@bd.LastTrickBonus</span>
                            <span class="rc-calc-bonus-label">★</span>
                        </span>
                    }
                    <span class="rc-calc-op eq">=</span>
                    <span class="rc-calc-val @(bd.FinalScore > 0 ? "pos" : bd.FinalScore < 0 ? "neg" : "")">@bd.FinalScore</span>
                </div>
            }
            else if (bd != null && !string.IsNullOrEmpty(bd.LossReason))
            {
                <div class="rc-pl-note">@LocalizeLossReason(bd.LossReason)</div>
            }
        </div>
    }
</div>

<!-- Footer info chip -->
@{
    string footText  = "";
    bool   footLoss  = false;
    if (IsSpecial)
    {
        footText = S.SpecialRoundNote;
    }
    else if (IsAbgegangen)
    {
        footText = S.BidderFoldedNote;
        footLoss = true;
    }
    else if (Round.LastTrickWinner >= 0 && Round.LastTrickWinner < Players.Count)
    {
        footText = string.Format(S.LastTrickNote, Rules.LastTrickBonus, Players[Round.LastTrickWinner]);
    }
}
@if (!string.IsNullOrEmpty(footText))
{
    <div class="rc-foot">
        <span class="rc-foot-chip @(footLoss ? "rc-foot-loss" : "")">@footText</span>
    </div>
}
