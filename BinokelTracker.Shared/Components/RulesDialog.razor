@if (_open)
{
    <div class="rules-overlay" @onclick="Close">
        <div class="rules-dialog" @onclick:stopPropagation>

            <div class="rules-header">
                <span class="rules-title">Binokel Regeln</span>
                <button class="btn" @onclick="Close" style="padding:4px">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <!-- ══ Meldbilder ══ -->
            <div class="rules-section-title">Meldbilder</div>

            <div class="rules-group-label">Besondere Meldungen</div>
            <div class="rules-table">
                <div class="rules-row">
                    <span class="rules-name">Binokel <span class="rules-cards">♠D + ♦B</span></span>
                    <span class="rules-pts">40</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Doppelbinokel</span>
                    <span class="rules-pts rules-pts-high">300</span>
                </div>
            </div>

            <div class="rules-group-label">Konter (A – 10 – K – D – B)</div>
            <div class="rules-table">
                <div class="rules-row">
                    <span class="rules-name">Konter in Trumpf</span>
                    <span class="rules-pts">150</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Konter in Farbe</span>
                    <span class="rules-pts">150</span>
                </div>
            </div>

            <div class="rules-group-label">Familie (K + D)</div>
            <div class="rules-table">
                <div class="rules-row">
                    <span class="rules-name">Familie in Trumpf</span>
                    <span class="rules-pts">40</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Familie in Farbe</span>
                    <span class="rules-pts">20</span>
                </div>
            </div>

            <div class="rules-group-label">Vier gleiche</div>
            <div class="rules-table">
                <div class="rules-row">
                    <span class="rules-name">Vier Asse</span>
                    <span class="rules-pts rules-pts-high">100</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Vier Zehner</span>
                    <span class="rules-pts">80</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Vier Könige</span>
                    <span class="rules-pts">60</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Vier Ober</span>
                    <span class="rules-pts">40</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Vier Unter</span>
                    <span class="rules-pts">40</span>
                </div>
            </div>

            <!-- ══ Augenwerte ══ -->
            <div class="rules-section-title" style="margin-top:20px">Augenwerte</div>
            <div class="rules-table">
                <div class="rules-row">
                    <span class="rules-name">Ass</span>
                    <span class="rules-pts rules-pts-high">11</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Zehn</span>
                    <span class="rules-pts rules-pts-high">10</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">König</span>
                    <span class="rules-pts">4</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Ober</span>
                    <span class="rules-pts">3</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Unter</span>
                    <span class="rules-pts">2</span>
                </div>
                <div class="rules-row">
                    <span class="rules-name">Sieben</span>
                    <span class="rules-pts rules-pts-zero">0</span>
                </div>
                <div class="rules-row rules-row-special">
                    <span class="rules-name">Letzter Stich</span>
                    <span class="rules-pts">10</span>
                </div>
            </div>

        </div>
    </div>
}

@code {
    private bool _open;

    public void Open()
    {
        _open = true;
        StateHasChanged();
    }

    private void Close() => _open = false;
}

<style>
    .rules-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,0.6);
        z-index: 200; display: flex; align-items: flex-end; justify-content: center;
        padding: 0 0 var(--safe-bottom);
    }

    .rules-dialog {
        background: var(--card); border-radius: 20px 20px 0 0;
        border: 1px solid var(--border); border-bottom: none;
        width: 100%; max-width: 480px; padding: 20px 18px 28px;
        display: flex; flex-direction: column; gap: 6px;
        max-height: 88vh; overflow-y: auto;
    }

    .rules-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 6px;
    }
    .rules-title {
        font-size: 16px; font-weight: 700; color: var(--accent);
    }

    .rules-section-title {
        font-size: 13px; font-weight: 700; letter-spacing: 0.08em;
        text-transform: uppercase; color: var(--accent-light);
        margin-top: 4px; margin-bottom: 2px;
    }

    .rules-group-label {
        font-size: 12px; font-weight: 600; color: var(--muted);
        margin-top: 10px; margin-bottom: 2px;
    }

    .rules-table {
        display: flex; flex-direction: column;
        border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
    }

    .rules-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 9px 12px; border-bottom: 1px solid var(--border);
        font-size: 14px;
    }
    .rules-row:last-child { border-bottom: none; }
    .rules-row-special {
        background: rgba(255,255,255,0.03);
        border-top: 1px solid var(--border);
    }

    .rules-name { color: var(--text); }
    .rules-cards { color: var(--muted); font-size: 13px; margin-left: 4px; }

    .rules-pts {
        font-weight: 700; font-size: 15px; color: var(--accent-light);
        min-width: 36px; text-align: right;
    }
    .rules-pts-high { color: var(--accent); }
    .rules-pts-zero { color: var(--dark); }
</style>
